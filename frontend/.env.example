# PocketBase URL (no trailing slash). Default: http://localhost:8090
NEXT_PUBLIC_PB_URL=http://localhost:8090

NEXT_PUBLIC_APP_NAME="Xperience Delivery"
NEXT_PUBLIC_BASE_CURRENCY=USD
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Payments (publishable / public keys only — never put secrets here)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
NEXT_PUBLIC_MONNIFY_API_KEY=
NEXT_PUBLIC_MONNIFY_CONTRACT_CODE=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
