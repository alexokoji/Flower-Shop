# Server-side payment secrets — set these when running `pocketbase serve`.
# On Windows PowerShell:
#   $env:PAYSTACK_SECRET_KEY="sk_test_..."; .\pocketbase.exe serve
# On bash:
#   PAYSTACK_SECRET_KEY=sk_test_... ./pocketbase serve

PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WEBHOOK_SECRET=

# Frontend origin allowed to use the API (CORS). Defaults to localhost:3000.
FRONTEND_URL=http://localhost:3000
